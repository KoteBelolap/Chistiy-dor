// ===== chapter2.ink =====
// Глава II. Следы под обшивкой
// Версия: 2.0 | Платформа: Урсула (Ink runtime)
// Исправления:
// - Синхронизированы ID локаций с locations.ink/main.ink ("belltower", "church_interior", "undercroft")
// - Исправлена логика исследования: check_point() теперь возвращает поток в сцену, а не ломает цикл
// - Убраны лишние пробелы в тегах и ID спрайтов
// - Добавлены корректные вызовы apply_scene() и say()

-> II_01_start

=== II_01_start
// SCENE II_01. Колокольня / день
{ apply_scene("belltower", "almost_silence", "wood_creak", "andrey", "suit_half_straight") }

-> say(andrey, suit_half_straight, "Запиши это в смету. «Упрямство — две единицы».")
-> say(alexey, half_smile, "Упрямство дороже.")
-> say(andrey, suit_half_straight, "Лёш, мне нравится твоя поэзия, когда она не мешает срокам.")
-> alexey_thought("Ложный циферблат был выцветшим, но стрелки держались. Шесть семнадцать. Не время — застрявшая дата. Церковь не показывала, который час. Она показывала, сколько ей пришлось пережить после него.")

// CHOICE II_A. Фиксация ложных часов
* [«Декоративный элемент, требует фотофиксации».]
    ~ apply_axis("authenticity", 1)
    ~ diary_add("Колокольня", "Ложные циферблаты. Фиксировать как декоративно-исторический слой без символических допущений.")
    -> II_02_intro

* [«Символ 1767 года, сильная деталь для истории».]
    ~ apply_axis("compromise", 1)
    ~ diary_add("Колокольня", "Часы можно подать как образ застывшего времени. Рабочая метафора для презентации.")
    -> II_02_intro

* [«Не выбирать между фактом и ощущением».]
    ~ apply_axis("authenticity", 1)
    ~ apply_axis("involvement", 1)
    ~ diary_add("Колокольня", "Часы: факт — ложные циферблаты. Ощущение — время, которое не идёт, но не исчезает. Не смешивать. Сохранить оба слоя.")
    -> II_02_intro

=== II_02_intro
// SCENE II_02. Притвор / следы краски (точка входа в осмотр)
{ apply_scene("church_interior", "strings_tension", "paper_rustle", "alexey", "half_smile") }
{ start_exploration("narthex", 3, -> II_02_explore) }
-> II_02_explore

=== II_02_explore
// Механика: Point-and-Click. Требуется осмотреть 3 точки.
<> [🔍 Притвор: осмотрено {loc_points_found}/3 точек]

* [Осмотреть обшивку]
    { check_point("paint_blue") }
    -> say(andrey, suit_half_straight, "Синяя церковь продаётся лучше белой?")
    -> say(alexey, half_smile, "Это не товарная карточка.")
    -> say(andrey, suit_half_straight, "Пока нет. Но, если честно, цвет помогает людям представить прошлое.")
    -> say(alexey, half_smile, "Прошлое не обязано помогать людям удобно себя чувствовать.")
    -> II_02_explore

* [Осмотреть след двери]
    { check_point("door_trace") }
    -> say(alexey, half_smile, "Здесь был другой проход. Или хотя бы другая логика движения.")
    -> say(varvara, braid_book, "То есть люди входили иначе?")
    -> say(alexey, half_smile, "Возможно. Или здание потом заставили вести себя иначе.")
    -> say(varvara, braid_book, "С людьми так тоже делают.")
    -> II_02_explore

* [Осмотреть фрагмент дерева]
    { check_point("wood_fragment") }
    -> alexey_thought("Фрагмент был лёгкий, почти ничего не весил. Но пальцы вдруг стали осторожными, будто я держал не дерево, а последнюю фразу человека, которого перебили.")
    -> say(andrey, suit_half_straight, "Что там?")
    -> say(alexey, half_smile, "Не знаю. Роспись. Возможно, часть внутреннего убранства.")
    -> say(andrey, suit_half_straight, "Звучит как находка.")
    -> say(alexey, half_smile, "Пока звучит как предмет, который просит не торопиться.")
    -> II_02_explore

* [Закончить осмотр притвора]
    { loc_points_found < 3:
        <> [⚠️ Нужно осмотреть минимум 3 точки, прежде чем продолжить.]
        -> II_02_explore
    - else:
        <> [✅ Осмотр завершён. Переходим в подклет.]
        -> II_03_start
    }

=== II_03_start
// SCENE II_03. Подклет / первая вспышка
{ apply_scene("undercroft", "silence_tension", "water_drip", "alexey", "half_smile") }

-> alexey_thought("Я опустил фонарь ниже. Пыль поднялась и закрыла доски. В какой-то миг запах сырого дерева сменился запахом мела. Это было невозможно. Просто память тела, усталость, темнота. Но я услышал, как кто-то листает страницы.")
<> #VISUAL:flash_school_room
<> Голос Миропии:  Не гасите лампу. Они ещё пишут.

-> say(alexey, half_smile, "Кто здесь?")
-> set_sprite(andrey, suit_half_straight)
-> say(andrey, suit_half_straight, "Ты чего?")
-> say(alexey, half_smile, "Ничего. Показалось.")
-> say(andrey, suit_half_straight, "Лёш, у нас не экспедиция за привидениями.")
-> say(alexey, half_smile, "Здесь и без привидений достаточно тех, кого не дослушали.")

// CHOICE II_B. Реакция на вспышку
* [Подавить и работать дальше.]
    ~ apply_axis("authenticity", 1)
    ~ diary_add("Подклет", "Сенсорная реакция в подклете. Не учитывать. Возможна усталость.")
    -> II_04_conclusion

* [Рассказать Варваре позже.]
    ~ apply_axis("trust_varvara", 1)
    ~ apply_axis("involvement", 1)
    ~ diary_add("Подклет", "В подклете на секунду показалось, что церковь помнит школу. Бред. Но я почему-то хочу рассказать Варваре.")
    -> II_04_conclusion

* [Использовать как будущий образ презентации.]
    ~ apply_axis("compromise", 1)
    ~ diary_add("Подклет", "Подклет даёт сильный эмоциональный ход: школа как голос под храмом. Опасно, но работает.")
    -> II_04_conclusion

=== II_04_conclusion
// SCENE II_04. Закрытие главы, переход к Главе III
{ apply_scene("church_interior", current_music, current_sfx, "alexey", "half_smile") }
-> alexey_thought("Церковь менялась. Слои накладывались, закрывались, стирались. Но под белой обшивкой всё ещё дышало то, что было здесь до нас.")

* [Перейти к библиотеке и школьным бумагам.] -> chapter3_start