// ===== chapter4.ink =====
// Глава IV. Миропия. Находка тетради, чтение фрагментов, ночной разговор у реки, раскрытие травмы.
// Версия: 1.0 | Платформа: Урсула (Ink runtime)
// Зависимости: main.ink, characters.ink, mechanics.ink, locations.ink, chapter5.ink

// Флаги прочитанных фрагментов и счётчик
VAR iv_fragments_read = 0
VAR iv_f1 = false
VAR iv_f2 = false
VAR iv_f3 = false
VAR iv_f4 = false
VAR iv_f5 = false

-> IV_01_start

=== IV_01_start
// SCENE IV_01. Библиотека / находка тетради
{ apply_scene("library", "miropiya_theme", "paper_rustle", "varvara", "braid_book") }
~ iv_fragments_read = 0

-> say(varvara, braid_book, "Подождите. Это не из этой папки.")
-> say(alexey, half_smile, "Что там?")
-> say(varvara, headscarf, "Тетрадь. Без обложки почти. Почерк женский, конец девятнадцатого или начало двадцатого. Здесь имя... Миропия.")
-> say(alexey, half_smile, "Янусова?")
-> say(varvara, braid_book, "Смотрите. «У Николая Павловича сегодня опять спрашивали про книги».")
-> alexey_thought("Имя не прозвучало громко. Оно не вошло в комнату. Оно вернулось туда, где давно лежало, и вдруг стало слышно.")

~ collect_clue("clue_miropiya_notebook")
~ miropiya_voice += 1
~ diary_add("Глава IV", "Найдена тетрадь Миропии Янусовой. Голос прошлого материализуется.")
<> [🔍 Найдено: Тетрадь Миропии]
<> [📓 Дневник: "Найдена тетрадь Миропии Янусовой. Голос прошлого материализуется."]

-> IV_02_fragments

=== IV_02_fragments
// Механика: Игрок выбирает 3 из 5 фрагментов. 5-й открывается при trust_varvara >= 2.
<> [📖 Чтение фрагментов: прочитано {iv_fragments_read}/3]

{ iv_f1 == false:
    + [Список учеников]
        ~ iv_f1 = true
        ~ iv_fragments_read += 1
        <> Голос Миропии: «Семён опять пишет букву так, будто строит забор. Марья стыдится читать вслух, но когда думает, что её не слышат, читает лучше всех».
        -> say(varvara, braid_book, "Вот. Видите? Не «ученики в количестве». Семён. Марья. Конкретные дети.")
        -> say(alexey, half_smile, "Документ с сердцем. Редкая вещь.")
        -> IV_02_fragments
}

{ iv_f2 == false:
    + [Дрова и холод]
        ~ iv_f2 = true
        ~ iv_fragments_read += 1
        <> Голос Миропии: «Дров на неделю не хватит. Просила принести из дома, кто может. Нельзя учить, когда пальцы у детей синие».
        -> say(alexey, half_smile, "Она не отделяла школу от быта.")
        -> say(varvara, braid_book, "Потому что жизнь не делится на разделы отчёта.")
        -> IV_02_fragments
}

{ iv_f3 == false:
    + [Книги]
        ~ iv_f3 = true
        ~ iv_fragments_read += 1
        <> Голос Миропии: «Старые книги велела не выносить без записи. Отец говорит: книга переживает человека, если человек не трусит перед теми, кто велит сжечь».
        -> say(alexey, half_smile, "Это уже не просто школьная тетрадь.")
        -> say(varvara, braid_book, "А что?")
        -> say(alexey, half_smile, "Инструкция по сопротивлению исчезновению.")
        -> IV_02_fragments
}

{ iv_f4 == false:
    + [Крест]
        ~ iv_f4 = true
        ~ iv_fragments_read += 1
        <> Голос Миропии: «То, что нельзя оставить на виду, не всегда надо отдавать. Иногда надо спрятать так, чтобы нашёл не враг, а свой. Но как узнать своего?».
        -> say(varvara, braid_book, "Крест. Егор Фомич говорил, что старики что-то прятали у воды.")
        -> say(alexey, half_smile, "Нужно поговорить с ним ещё раз.")
        -> IV_02_fragments
}

{ trust_varvara >= 2 && iv_f5 == false:
    + [Не делайте из нас красивых]
        ~ iv_f5 = true
        ~ iv_fragments_read += 1
        <> Голос Миропии: «Если кто-то потом найдёт эти листы, не делайте из нас красивых. Мы были усталые, иногда злые, иногда трусливые. Но мы держали, что могли. Этого достаточно».
        -> say(varvara, headscarf, "Боже...")
        -> say(alexey, half_smile, "Вот она. Главная фраза.")
        -> say(varvara, braid_book, "Какая?")
        -> say(alexey, half_smile, "Не делайте из нас красивых.")
        -> IV_02_fragments
}

* [Закончить чтение]
    { iv_fragments_read < 3:
        <> [⚠️ Нужно прочитать минимум 3 фрагмента, чтобы составить целостную картину.]
        -> IV_02_fragments
    - else:
        <> [✅ Чтение завершено. Образы складываются в живую картину.]
        -> IV_03_river
    }

=== IV_03_river
// SCENE IV_03. Берег реки / ночь
{ apply_scene("riverbank", "theme_varvara", "river_flow", "varvara", "headscarf") }

-> say(varvara, headscarf, "Когда я была маленькая, мне казалось, что река всё уносит. Потом я поняла, что она ещё и возвращает. Только не сразу.")
-> say(alexey, half_smile, "Удобное свойство для памяти.")
-> say(varvara, headscarf, "Неудобное. Ждёшь не то, что хочешь. Получаешь не тогда, когда готов.")
-> say(alexey, half_smile, "Я однажды сделал проект. Не один, конечно. Команда, инвесторы, сроки. Памятник был настоящий, а мы сделали из него убедительную картинку. Очень грамотную. Очень чистую. Там даже благодарности были.")
-> say(varvara, headscarf, "И что?")
-> say(alexey, half_smile, "Все сказали: спасли. А я смотрел и понимал, что мы не спасли. Мы сделали так, чтобы никто больше не заметил, что он умер раньше.")

// CHOICE IV_A. Открыть прошлую травму до конца?
* [Рассказать честно]
    ~ past_wound_open = true
    ~ trust_varvara += 1
    -> say(alexey, half_smile, "Я подписал часть материалов. Не главную. Но подписал. Мне хватило одной подписи, чтобы потом годами чувствовать её на руке.")
    -> say(varvara, headscarf, "Спасибо, что сказали.")
    -> say(alexey, half_smile, "За это не благодарят.")
    -> say(varvara, headscarf, "Благодарят. Когда человек мог спрятаться за «опыт», а вместо этого назвал вину виной.")
    -> IV_03_end

* [Свернуть разговор]
    ~ authenticity += 1
    -> say(alexey, half_smile, "Неважно. Просто не хочу повторить.")
    -> say(varvara, headscarf, "Иногда «неважно» — это дверь, которую человек держит плечом. Я не буду ломиться.")
    -> IV_03_end

* [Перевести в профессиональную плоскость]
    ~ compromise += 1
    -> say(alexey, half_smile, "Поэтому я понимаю, как рождаются компромиссы. Не от злости. От усталости, сроков и фраз вроде «иначе ничего не будет».")
    -> say(varvara, headscarf, "Да. Самые опасные подмены приходят не с ножом. Они приходят с календарём.")
    -> IV_03_end

=== IV_03_end
// Проверка уровня доверия для физической близости
{ trust_varvara >= 3:
    -> say(varvara, headscarf, "Вы завтра уедете?")
    -> say(alexey, half_smile, "Нет.")
    -> say(varvara, headscarf, "Почему?")
    -> say(alexey, half_smile, "Потому что тетрадь ещё не дочитана.")
    -> say(varvara, headscarf, "Только поэтому?")
    -> say(alexey, half_smile, "Нет.")
    <> [🎭 Варвара берёт Алексея за руку. Контакт тихий, но значимый.]
- else:
    -> say(varvara, headscarf, "Вы завтра уедете?")
    -> say(alexey, half_smile, "Нет.")
    -> say(varvara, headscarf, "Почему?")
    -> say(alexey, half_smile, "Потому что тетрадь ещё не дочитана.")
    -> say(varvara, headscarf, "Только поэтому?")
    -> say(alexey, half_smile, "Нет.")
    <> [🎭 Варвара стоит рядом, но не касается. Дистанция сохраняется, но мост построен.]
}
-> say(varvara, headscarf, "Тогда не врите завтра. Ни им. Ни себе.")
-> IV_04_night_church

=== IV_04_night_church
// SCENE IV_04. Ночная церковь / внутренний монолог
{ apply_scene("church_interior", "silence_tension", "wind_wood", "alexey", "half_smile") }
<> #VISUAL:flash_school_tetrad_blue_clock

-> alexey_thought("Я снова вошёл в церковь ночью. Доски молчали. И всё же в этом молчании было больше речи, чем во всех наших будущих презентациях.")
-> say(miropiya, book_neutral, "Не делайте из нас красивых.")
-> say(alexey, half_smile, "Я постараюсь.")
-> say(miropiya, book_neutral, "Стараться мало, Алексей Воронцов.")
-> alexey_thought("Я не испугался, что услышал своё имя. Я испугался, что придумал его сам. Потому что тогда отвечать было не перед прошлым, а перед собой.")

~ diary_add("Глава IV", "Миропия. Школа. Книги. Крест у воды. Главная фраза: не делать красивыми. Сохранить не легенду, а право быть настоящими.")
<> [📓 Дневник записан]

* [Перейти к берегу реки утром (Глава V)] -> chapter5_start