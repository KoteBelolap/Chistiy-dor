// ===== endings.ink =====
// Реализация трёх концовок: «Подмена», «Архив», «Память»
// Версия: 1.0 | Платформа: Урсула (Ink runtime)
// Зависимости: main.ink, characters.ink, mechanics.ink
// Примечание: Все сцены точно соответствуют сценарию, ветвления управляются скрытыми осями.

// =============================================================================
// 🟥 МАРШРУТ А: «ПОДМЕНА» (Compromise Route)
// =============================================================================
=== ending_substitution_start
{ apply_scene("workshop", "ad_cold", "none", "varvara", "headscarf") }
-> say(varvara, headscarf, "Вы правда это говорите?")
-> say(alexey, half_smile, "Я говорю, что место надо сначала удержать физически. Потом можно будет уточнять.")
-> say(varvara, braid_book, "У лжи нет «потом», Алексей. У неё есть только ремонт.")
-> say(andrey, suit_half_straight, "Не надо так. Мы никого не обманываем. Мы расставляем акценты.")
-> say(varvara, braid_book, "Вы убираете всё, что мешает продать аккуратную грусть.")
-> say(alexey, half_smile, "Варя...")
-> say(varvara, braid_book, "Не сокращайте моё имя сейчас. Не надо делать вид, что между нами осталась та близость, которая выдержит это решение.")
-> say(varvara, headscarf, "Я правда думала, что вы слышите. Не меня. Её. Миропию. Детей. Стариков. Оказывается, вы просто хорошо записывали.")
-> say(varvara, braid_book, "Предательство редко начинается с желания. Чаще — с убедительного объяснения.")
-> ending_substitution_montage

=== ending_substitution_montage
{ apply_scene("church_interior", "ad_cold", "camera_shutter", "andrey", "suit_half_straight") }
-> alexey_thought("Мы не написали прямой лжи. В этом была особая чистота преступления. Мы просто убрали сомнение. Синие следы стали «цветовой памятью». Тетрадь Миропии — «дневником хранительницы». Крест из воды — «символом возвращения веры».")
-> say(andrey, suit_half_straight, "Отлично. Вот это уже можно показывать. Понятно, берёт за сердце, не расползается.")
-> say(alexey, half_smile, "Она расползалась потому, что была живой.")
-> say(andrey, suit_half_straight, "Живое надо монтировать, иначе зритель уйдёт.")
-> say(alexey, half_smile, "А если уйдёт не зритель, а смысл?")
-> say(andrey, suit_half_straight, "Смысл без зрителя тоже долго не живёт.")
-> ending_substitution_opening

=== ending_substitution_opening
{ apply_scene("churchyard", "ad_cold", "crowd_murmur", "alexey", "tired") }
<> #VISUAL:large_opening_event
<> Ведущий:  Благодаря совместной работе специалистов, жертвователей и неравнодушных людей мы возвращаем Чистому Дору его утраченную святыню.
-> alexey_thought("Все улыбались. Белая обшивка сияла. Часы на колокольне всё так же показывали шесть семнадцать. Только теперь они казались не следом прошлого, а декорацией, которую мы забыли снять после спектакля.")
-> say(andrey, suit_half_straight, "Ты сделал хорошую работу.")
-> say(alexey, half_smile, "Да. Хорошую.")
-> say(andrey, suit_half_straight, "Почему тогда такое лицо?")
-> say(alexey, half_smile, "Потому что хорошая работа иногда хуже плохой. Плохую видно.")
-> alexey_thought("Я уехал вечером. В зеркале заднего вида церковь была красивой, цельной, спасённой. И впервые за всё время не похожей на себя.")

// Вариация концовки по уровню compromise
{ compromise >= 5:
    <> [🏁 КОНЦОВКА: «Подмена» (Успешная реализация)]
    <> Алексей получает внешнее признание и проектное финансирование. Но цена — утрата подлинности и разрыв с Варварой.
- else:
    <> [🏁 КОНЦОВКА: «Подмена» (Вынужденное решение)]
    <> Алексей уступает давлению ради выживания объекта. Проект стартует, но внутренний конфликт не разрешён.
}
~ diary_add("Финал", "Мы не соврали. Мы сделали хуже: оставили только те части правды, которые не мешали.")
-> END

// =============================================================================
// 🟦 МАРШРУТ Б: «АРХИВ» (Authenticity Route)
// =============================================================================
=== ending_archive_start
{ apply_scene("workshop", "silence_tension", "paper_rustle", "alexey", "firm") }
-> say(alexey, half_smile, "Мы не имеем права превращать это в легенду. Все находки нужно описать, опечатать, передать на экспертизу. До заключений — никаких маршрутов, стендов и эмоциональных формулировок.")
-> say(andrey, suit_half_straight, "Ты понимаешь, что это остановит проект?")
-> say(alexey, half_smile, "Зато не исказит материалы.")
-> say(varvara, braid_book, "А место?")
-> say(alexey, half_smile, "Место сохранится через документы.")
-> say(varvara, headscarf, "Не всё, что сохранено в документах, выживает здесь.")
-> say(alexey, half_smile, "Я знаю. Но я не хочу второй раз подписывать красивую неправду.")
-> say(varvara, headscarf, "Я уважаю это. Правда.")
-> say(alexey, half_smile, "Но?")
-> say(varvara, braid_book, "Но иногда человек так боится солгать, что перестаёт говорить вообще.")
-> ending_archive_catalog

=== ending_archive_catalog
{ apply_scene("workshop", "piano_lonely", "camera_shutter", "", "") }
-> alexey_thought("Мы работали правильно. На каждом предмете появлялась бирка. На каждой гипотезе — знак вопроса. Тетрадь Миропии легла в бескислотную папку. Крест — в отдельный контейнер.")
<> Специалист:  Материалы ценные. Нужно вывозить хотя бы часть. Здесь условия не подходят.
-> say(varvara, headscarf, "То есть опять увозить?")
<> Специалист:  Сохранять.
-> say(varvara, headscarf, "Это слово у вас каждый раз звучит как «забрать».")
-> say(alexey, half_smile, "Варя, они правы по условиям.")
-> say(varvara, headscarf, "Я знаю. Мне от этого не легче.")
-> ending_archive_farewell

=== ending_archive_farewell
{ apply_scene("road_church", "piano_lonely", "wind_wood", "varvara", "sad") }
-> say(varvara, headscarf, "Ваша статья будет хорошей.")
-> say(alexey, half_smile, "Не знаю.")
-> say(varvara, headscarf, "Будет. Вы умеете не врать.")
-> say(alexey, half_smile, "Этого оказалось мало.")
-> say(varvara, headscarf, "Нет. Это много. Просто не всё.")
-> say(alexey, half_smile, "Я думал, вы будете злиться.")
-> say(varvara, headscarf, "Я и злюсь. Но злость не отменяет уважения.")
-> say(varvara, braid_book, "Возвращайтесь не как человек, который всё понял. Здесь таких уже было много. Возвращайтесь как человек, который готов снова не знать.")
-> ending_archive_return

=== ending_archive_return
{ apply_scene("old_village", "theme_varvara_sad", "snow_wind", "alexey", "tired") }
-> alexey_thought("Статья вышла через восемь месяцев. Её хвалили за строгость. За осторожную работу с источниками. Я читал рецензии и чувствовал не радость, а тишину.")
-> alexey_thought("Когда я вернулся в Чистый Дор, церковь стояла законсервированная. Не разрушенная. Не спасённая. Сохранённая в том странном состоянии, когда смерть отменили, а жизнь ещё не разрешили.")
-> say(varvara, headscarf, "Здравствуйте, Алексей.")
-> say(alexey, half_smile, "Здравствуйте, Варвара.")
-> say(varvara, headscarf, "В библиотеке сделали копии части материалов. Приходите, если хотите посмотреть.")
-> say(alexey, half_smile, "Хочу.")
-> say(varvara, headscarf, "Тогда пойдёмте. Только медленно. Здесь всё теперь медленно.")
-> alexey_thought("Мы шли рядом. Не чужие. Не вместе. Между нами лежала правильная работа, и она была слишком холодной, чтобы согреть руки.")

// Вариация по уровню authenticity
{ authenticity >= 5:
    <> [🏁 КОНЦОВКА: «Архив» (Научное признание)]
    <> Алексей сохраняет профессиональную честь. Место законсервировано, память защищена, но живая связь утрачена.
- else:
    <> [🏁 КОНЦОВКА: «Архив» (Страх вместо строгости)]
    <> Выбор продиктован не столько научной добросовестностью, сколько страхом повторной ошибки. Тишина становится громче правды.
}
~ diary_add("Финал", "Правда в коробке не погибает. Но иногда перестаёт согревать тех, кто жил рядом с ней.")
-> END

// =============================================================================
// 🟩 МАРШРУТ В: «ПАМЯТЬ» (Involvement Route)
// =============================================================================
=== ending_memory_start
{ apply_scene("workshop", "theme_hope", "none", "alexey", "firm") }
-> say(alexey, half_smile, "Нет. Мы не будем делать легенду. И не будем вывозить из деревни всё, что наконец заговорило.")
-> say(andrey, suit_half_straight, "Тогда что ты предлагаешь? Молитву вместо проекта?")
-> say(alexey, half_smile, "Проект. Только честный. С разделением факта, гипотезы и местного свидетельства. С консервацией следов, а не зачисткой.")
-> say(andrey, suit_half_straight, "Фонд не поймёт.")
-> say(alexey, half_smile, "Поймёт, если перестать считать его глупее нас.")
-> say(varvara, headscarf, "А если не поймёт?")
-> say(alexey, half_smile, "Тогда мы потеряем быстрые деньги, но не потеряем право говорить от своего имени.")
-> say(andrey, suit_half_straight, "Это романтика.")
-> say(alexey, half_smile, "Нет. Романтика — думать, что красивый макет спасает совесть.")

{ clues_count >= 7:
    -> say(alexey, hands_smile, "У нас есть след синей краски. Ложные часы. Старый проём. Школа 1884 года. Отдельное здание 1897 года. Список книг. Тетрадь Миропии. Рассказ о кресте. Фрагмент иконостаса. Это не одна гладкая история. Это сеть. И её нельзя выдёргивать из земли.")
- else:
    -> alexey_thought("Карты памяти не хватает до полного набора, но я не могу молчать.")
}

-> say(andrey, suit_half_straight, "Ты берёшь на себя ответственность?")
-> say(alexey, half_smile, "Да.")
-> say(varvara, braid_book, "Не за нас?")
-> say(alexey, half_smile, "Нет. С вами.")
-> ending_memory_presentation

=== ending_memory_presentation
{ apply_scene("workshop", "theme_hope", "projector_hum", "andrey", "suit_half_straight") }
<> Представитель фонда:  Мы ожидали увидеть концепцию восстановления. А здесь предлагается оставить часть следов разрушения видимыми?
-> say(alexey, half_smile, "Не разрушения. Времени. Разрушение мы остановим. Но не будем стирать следы, которые являются источниками.")
<> Представитель фонда:  Это сложнее для посетителя.
-> say(varvara, braid_book, "Посетитель не ребёнок. Ему можно доверить сложное.")
-> say(andrey, suit_half_straight, "Коллеги предлагают более деликатную модель интерпретации. Она рискованнее, но может дать проекту уникальность.")
-> say(alexey, half_smile, "Не уникальность. Честность. Уникальность — побочный эффект.")

{ clues_count >= 7 && involvement >= 4:
    <> Представитель фонда:  Хорошо. Начнём с пилотного этапа. Консервация, копии документов на месте, маршрут памяти. Но отчётность будет строгой.
    ~ diary_add("Презентация", "Фонд принял пилотный этап. Работа начинается по-настоящему.")
- else:
    <> Представитель фонда:  Мы дадим ограниченное финансирование на консервацию. Дальше — только волонтёры и местная программа.
    ~ diary_add("Презентация", "Фонд отступил. Начинаем с малого, но на своих условиях.")
}
-> say(andrey, suit_half_straight, "С отчётностью мы справимся.")
-> say(varvara, headscarf, "Только без превращения отчёта в повод всё упростить.")
-> ending_memory_center

=== ending_memory_center
{ apply_scene("churchyard", "theme_hope", "quiet_steps", "alexey", "hands_smile") }
-> alexey_thought("Мы не сделали церковь новой. Не заставили её улыбаться гостям. Не спрятали трещины, не придумали недостающие лица, не выпрямили историю до удобного маршрута.")
-> alexey_thought("Мы укрепили то, что падало. Закрыли то, что могло погибнуть от воды. Оставили видимым то, что имело право свидетельствовать.")
-> say(egor, surprised_map, "Пустые строки — это ты придумал?")
-> say(alexey, half_smile, "Мы с Варварой.")
-> say(egor, surprised_map, "Правильно. Не всех же помним. А будто место им оставили.")
-> say(andrey, suit_half_straight, "Знаете, Алексей, я всё ещё считаю, что презентация могла быть сильнее. Но эта почему-то дольше держится в голове.")
-> say(alexey, half_smile, "Потому что ей не надо притворяться законченной.")

// Романтическая вариация финала
{ trust_varvara >= 4 && past_wound_open == true:
    -> say(varvara, braid_book, "Вы правда остаетесь?")
    -> say(alexey, half_smile, "У меня завтра встреча с плотниками, послезавтра — с архивом. Через неделю надо ехать за материалами. Похоже, я попал в ловушку.")
    -> say(varvara, braid_book, "Местная память коварна.")
    -> say(alexey, half_smile, "И один её главный хранитель тоже.")
    -> say(varvara, headscarf, "Главный хранитель сейчас думает, можно ли вам доверять ключи от библиотеки.")
    -> say(alexey, half_smile, "И что решил?")
    -> say(varvara, braid_book, "Что ключи — рано. А вот чай после работы — можно.")
    -> say(alexey, half_smile, "Согласен на пилотный этап.")
    -> say(varvara, braid_book, "Смотрите, реставратор. Пилотный этап иногда превращается в жизнь.")
    -> say(alexey, half_smile, "Я на это рассчитываю.")
    <> [💚 Истинная концовка: «Память» — Общее дело и личное будущее]
- else if trust_varvara >= 2:
    -> say(varvara, headscarf, "Вы правда остаетесь до конца этапа?")
    -> say(alexey, half_smile, "Да. А дальше посмотрим, что скажет место.")
    -> say(varvara, braid_book, "Тогда начнём с малого. Завтра библиотека. В девять.")
    -> say(alexey, half_smile, "Буду.")
    <> [🤝 Концовка: «Память» — Перспектива и взаимное уважение]
- else:
    -> say(varvara, headscarf, "Начните с завтра. Большие решения всё равно проверяются утром.")
    <> [🌱 Концовка: «Память»