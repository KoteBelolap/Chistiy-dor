// ===== prologue.ink =====
// Пролог. Знакомство с Алексеем, Андреем Михайловичем и первой реакцией на поездку.
// Версия: 2.0 | Платформа: Урсула (Ink runtime)
// Исправления:
// - Убраны лишние пробелы в ID локаций ("road_church" -> "road") для соответствия locations.ink/main.ink
// - Добавлены вызовы apply_scene() с корректными параметрами
// - Синхронизированы изменения переменных через apply_axis()
// - Исправлен синтаксис тегов #BG, #CHAR (добавлены пробелы после <>)

-> prologue_start

=== prologue_start
// SCENE P0_01. Дорога / салон машины / вечер
{ apply_scene("road", "piano_lonely", "car_engine", "alexey", "half_smile") }

-> alexey_thought("Дорога к деревне всегда начинается одинаково: сначала исчезает связь, потом уверенность, потом желание объяснять себе, зачем ты едешь.")
-> alexey_thought("На коленях лежала папка. Шесть фотографий, две справки, один предварительный план работ. Этого обычно хватает, чтобы объект стал задачей.")

-> say(andrey, suit_half_straight, "Не смотри так, Лёш. Никто не просит тебя совершать подвиг. Надо приехать, посмотреть, собрать внятную концепцию и помочь людям получить деньги.")
-> say(alexey, half_smile, "Слово «внятную» обычно означает «без сложных мест».")
-> say(andrey, suit_half_straight, "Сложные места можно оставить специалистам. Жертвователю нужна ясность. Он должен понять, что спасает.")
-> say(alexey, hands_smile, "А если он спасает не то?")
-> say(andrey, suit_half_straight, "Тогда мы объясним так, чтобы спасал то. Ты же умеешь.")
-> alexey_thought("Вот именно. Умею.")

// CHOICE P0_A. Отношение Алексея к поездке
* [«Закрыть задачу и не цепляться».]
    ~ apply_axis("compromise", 1)
    -> say(alexey, hands_smile, "Я посмотрю, что можно сделать. Без романтики.")
    -> say(andrey, suit_half_straight, "Вот это мне и нужно. Холодная голова.")
    ~ diary_add("Дорога", "Чистый Дор. Первичный выезд. Не втягиваться. Зафиксировать, оценить, уехать.")
    -> prologue_arrival

* [«Попробовать услышать, что там на самом деле».]
    ~ apply_axis("involvement", 1)
    -> say(alexey, half_smile, "Сначала посмотрю. Потом решим, что там вообще можно объяснять.")
    -> say(andrey, suit_half_straight, "Смотри сколько хочешь. Только не забывай: объекту нужны не стихи, а бюджет.")
    ~ diary_add("Дорога", "Чистый Дор. Андрей торопит к концепции. Я почему-то не хочу торопиться.")
    -> prologue_arrival

* [«Сказать, что уже видел такие истории».]
    ~ apply_axis("authenticity", 1)
    // past_wound_open остается false по умолчанию, пока игрок не расскажет об этом в Главе IV
    -> say(alexey, hands_smile, "Я уже видел, как место спасали до полной неузнаваемости.")
    -> say(andrey, suit_half_straight, "Ты опять про тот проект?")
    -> say(alexey, half_smile, "Я не про него. Я про привычку называть подмену работой.")
    ~ diary_add("Дорога", "Не думать о прошлом проекте. Не переносить старую вину на новое место. Хотя вины, кажется, сроков давности не бывает.")
    -> prologue_arrival

=== prologue_arrival
// SCENE P0_02. Первое появление деревни
{ apply_scene("road", "piano_lonely", "car_engine", "alexey", "half_smile") }

-> say(andrey, suit_half_straight, "Вот она. Никольская.")
-> alexey_thought("Церковь стояла не как открытка. Не просилась в кадр. Не пыталась понравиться. Просто держалась на земле — устало, упрямо, как человек, который слишком долго отвечал за других.")

-> say(alexey, hands_smile, "Колокольня отдельно ставилась?")
-> say(andrey, suit_half_straight, "Была отдельная, потом подвинули. В справке есть. Ты же любишь такие вещи.")
-> say(alexey, half_smile, "Я люблю, когда вещи не заставляют притворяться цельными.")

// Переход к Главе I
* [Выйти из машины и направиться к двору.] -> chapter1_start