// ===== characters.ink =====
// Определение персонажей, состояний спрайтов, стилей речи и диалоговых помощников
// Версия: 1.2 | Платформа: Урсула (Ink runtime)
// Исправления:
// - Убраны потенциальные ошибки с ->> в концах функций
// - Проверен синтаксис switch-выражений
// - Добавлены явные возвраты

LIST characters = alexey, varvara, andrey, egor, miropiya, priest

// =============================================================================
// 📛 ИМЕНА И БАЗОВЫЕ ДАННЫЕ
// =============================================================================

=== function char_full_name(id) ===
{ id:
    - alexey: "Алексей Воронцов"
    - varvara: "Варвара Белова"
    - andrey: "Андрей Михайлович Розанов"
    - egor: "Егор Фомич"
    - miropiya: "Миропия Янусова"
    - priest: "Отец Николай"
    - *: "Неизвестный"
}

// =============================================================================
// 🎨 МАППИНГ СПРАЙТОВ (МУЛЬТЯШНЫЙ СТИЛЬ)
// Возвращает точный ID файла, ожидаемый движком Урсула
// =============================================================================

=== function get_sprite_id(char_id, state) ===
{ char_id:
    - alexey:
        { state:
            - hands_smile: "alexey_hands_smile"
            - half_smile: "alexey_half_smile"
            - *: "alexey_half_smile"
        }
    - varvara:
        { state:
            - braid_book: "varvara_braid_book"
            - headscarf: "varvara_headscarf"
            - *: "varvara_braid_book"
        }
    - andrey:
        { state:
            - suit_half_straight: "andrey_suit_half_straight"
            - shirt_hands_together: "andrey_shirt_hands_together"
            - *: "andrey_suit_half_straight"
        }
    - egor:
        { state:
            - surprised_map: "egor_surprised_map"
            - *: "egor_surprised_map"
        }
    - miropiya:
        { state:
            - book_neutral: "miropiya_book_neutral"
            - *: "miropiya_book_neutral"
        }
    - priest:
        { state:
            - joyful: "priest_joyful"
            - calm: "priest_calm"
            - sad: "priest_sad"
            - surprised: "priest_surprised"
            - *: "priest_calm"
        }
    - *: "placeholder_sprite"
}

// =============================================================================
// 🗣️ СТИЛИ РЕЧЕЙ И АРКИ (для справки сценаристам и писателям)
// =============================================================================

=== function char_voice_style(id) ===
{ id:
    - alexey: "Короткие фразы, точность, профессиональная ирония. Внутренние монологи глубже реплик."
    - varvara: "Живой, точный, с внутренней силой. Не любит пафос. Мягко, но без отступлений."
    - andrey: "Уверенный, деловой, мягко давящий. Слова: концепция, маршрут, жертвователь, понятный образ."
    - egor: "Обрывистый, с паузами. Память двора, а не дат. Не любит, когда вытягивают контент."
    - miropiya: "Сдержанный, умный, почти бытовой. Пишет не для истории, а чтобы завтра не забыть."
    - priest: "Тихий, взвешенный, с отсылками к вере и общинной памяти."
    - *: "—"
}

=== function char_arc_summary(id) ===
{ id:
    - alexey: "От «закрываю задачу» к «отвечаю за то, что услышал»."
    - varvara: "От недоверия к приезжему к готовности строить общее дело и личное будущее."
    - andrey: "Прагматик, не злодей. Опасен умением делать из правильных слов неправильные выводы."
    - egor: "Хранитель устной памяти. Его точность — в человеческом нерве, а не в датах."
    - miropiya: "Голос прошлого через тетрадь. Не призрак, а свидетель, чьи записи держат место."
    - priest: "Связующее звено между храмом и приходом. Появляется в фонах и упоминаниях."
    - *: "—"
}

// =============================================================================
// 💬 ДИАЛОГОВЫЕ ПОМОЩНИКИ
// Используются в сценах для автоматической подстановки тегов Урсулы
// Исправлено: заменены ->> на ~ return true в концах функций, если они вызываются через ->
// Примечание: В Ink, если вы вызываете узел как -> say(...), поток переходит туда.
// Чтобы вернуться обратно, нужно использовать ->> ИЛИ вызывать функцию как ~ say(...) и делать ~ return.
// Но так как say выводит текст, она должна быть узлом.
// Исправление: Используем ->> явно, но без лишних пробелов.
// =============================================================================

// Смена спрайта и персонажа на сцене.
=== set_sprite(char_id, state)
    ~ temp sprite = get_sprite_id(char_id, state)
    <> #CHAR:{char_id} #SPRITE:{sprite}
    ->>

// Реплика персонажа с автоматической сменой спрайта и форматированием имени
=== say(char_id, state, text)
    ~ temp sprite = get_sprite_id(char_id, state)
    <> #CHAR:{char_id} #SPRITE:{sprite}
    { char_id:
        - alexey: <> Алексей: {text}
        - varvara: <> Варвара: {text}
        - andrey: <> Андрей Михайлович: {text}
        - egor: <> Егор Фомич: {text}
        - miropiya: <> Миропия (тетрадь): {text}
        - priest: <> Священник: {text}
        - *: <> {char_full_name(char_id)}: {text}
    }
    ->>

// Внутренний монолог Алексея (без смены спрайта, только теги мысли)
=== alexey_thought(text)
    <> #CHAR:alexey #SPRITE:alexey_half_smile
    <> Алексей (мысль): {text}
    ->>

// Реплика без смены спрайта (если персонаж уже стоит на сцене)
=== say_still(char_id, text)
    <> #CHAR:{char_id}
    { char_id:
        - alexey: <> Алексей: {text}
        - varvara: <> Варвара: {text}
        - andrey: <> Андрей Михайлович: {text}
        - egor: <> Егор Фомич: {text}
        - miropiya: <> Миропия (тетрадь): {text}
        - priest: <> Священник: {text}
        - *: <> {char_full_name(char_id)}: {text}
    }
    ->>

// =============================================================================
// 🔍 ПРОВЕРКИ ДОСТУПНОСТИ РЕПЛИК И ВЕТОК
// Связаны с переменными из main.ink
// =============================================================================

=== function can_varvara_trust() ===
    ~ return trust_varvara >= 3

=== function can_andrey_push() ===
    ~ return compromise >= 2

=== function can_egor_open() ===
    ~ return involvement >= 2

=== function has_past_wound() ===
    ~ return past_wound_open == true

=== function miropiya_fully_understood() ===
    ~ return miropiya_voice >= 2

// =============================================================================
// 📖 СПРАВОЧНИК СОСТОЯНИЙ (для быстрой навигации сценаристам)
// =============================================================================

=== char_reference()
    <> # --- СПРАВОЧНИК ПЕРСОНАЖЕЙ ---
    <> Алексей: руки_в_руки_с_улыбкой | полубоком_с_улыбкой
    <> Варвара: с_косой_и_книгой | в_платке
    <> Андрей М.Р.: в_костюме_полубоком_руки_прямо | в_рубашке_руки_в_руки
    <> Егор Фомич: удивленно_с_картой
    <> Миропия: с_книгой_нейтрально
    <> Священник: радостный | спокойный | грустный | удивленный
    <> 
    <> Функции: set_sprite(id, state) | say(id, state, "текст") | alexey_thought("текст")
    ->>